# Copy this file to .env before running docker compose.
# Never commit .env. Never paste real API keys into JSON config files.

# Stage 1 is spot dry-run only. These placeholders are intentionally not used
# for live trading and must not contain withdrawal permission.
BINANCE_API_KEY=DRY_RUN_PLACEHOLDER_DO_NOT_USE_LIVE
BINANCE_API_SECRET=DRY_RUN_PLACEHOLDER_DO_NOT_USE_LIVE

OKX_API_KEY=DRY_RUN_PLACEHOLDER_DO_NOT_USE_LIVE
OKX_API_SECRET=DRY_RUN_PLACEHOLDER_DO_NOT_USE_LIVE
OKX_API_PASSPHRASE=DRY_RUN_PLACEHOLDER_DO_NOT_USE_LIVE

# Local-only Freqtrade WebUI credentials.
# Change these in .env for your own machine. WebUI is bound to 127.0.0.1 only.
FREQTRADE__API_SERVER__USERNAME=freqtrade
FREQTRADE__API_SERVER__PASSWORD=CHANGE_ME_LOCAL_DRYRUN_ONLY
FREQTRADE__API_SERVER__JWT_SECRET_KEY=CHANGE_ME_LOCAL_JWT_SECRET_DRYRUN_ONLY
FREQTRADE__API_SERVER__WS_TOKEN=CHANGE_ME_LOCAL_WS_TOKEN_DRYRUN_ONLY

